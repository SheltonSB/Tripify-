# Copy this file to `.env` at the repo root for Docker Compose.
DATABASE_URL=postgresql://app:app@tripify_postgres:5432/travel
REDIS_URL=redis://tripify_redis:6379
VITE_API_BASE_URL=http://localhost:8081
TRIPIFY_LLM_MODEL=llama3.2:3b
TRIPIFY_AMADEUS_CLIENT_ID=YOUR_AMADEUS_CLIENT_ID
TRIPIFY_AMADEUS_CLIENT_SECRET=YOUR_AMADEUS_CLIENT_SECRET
TRIPIFY_OPENWEATHER_API_KEY=YOUR_WEATHERAPI_KEY
TRIPIFY_GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY
TRIPIFY_TICKETMASTER_API_KEY=YOUR_TICKETMASTER_API_KEY
TRIPIFY_YELP_API_KEY=YOUR_YELP_API_KEY
TRIPIFY_PROVIDERS_AMADEUS_BASE_URL=https://test.api.amadeus.com
TRIPIFY_PROVIDERS_OPENWEATHER_BASE_URL=https://api.weatherapi.com
TRIPIFY_PROVIDERS_GOOGLE_PLACES_BASE_URL=https://places.googleapis.com
TRIPIFY_PROVIDERS_TICKETMASTER_BASE_URL=https://app.ticketmaster.com
TRIPIFY_PROVIDERS_YELP_BASE_URL=https://api.yelp.com
